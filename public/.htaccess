# Next.js Static Export - URL Rewriting
# Перенаправление для правильной работы роутинга

# Устанавливаем индексный файл по умолчанию
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTP_HOST} !^absolut-stal\.ru$ [NC]
  RewriteCond %{HTTP_HOST} !^www\.absolut-stal\.ru$ [NC]
  RewriteRule ^(.*)$ https://absolut-stal.ru/$1 [R=301,L]

  # Если запрашивается существующая директория без слэша на конце, добавляем слэш
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ /$1/ [L,R=301]

  # Любой запрос, заканчивающийся на слэш, принудительно перенаправляем (внутренне) на index.html
  RewriteRule ^(.*)/$ $1/index.html [L]

  # Для главной страницы (когда путь пустой)
  RewriteRule ^$ index.html [L]

  # Если запрашивается файл, которого нет, но есть такой же с .html на конце
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}\.html -f
  RewriteRule ^(.*)$ $1.html [L]

  # Обработка 404 ошибки
  ErrorDocument 404 /404.html
</IfModule>

# Кеширование статических файлов
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/json "access plus 1 month"
</IfModule>

# Gzip сжатие
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

